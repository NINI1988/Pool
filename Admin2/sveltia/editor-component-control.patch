+
+  /** @type {Props} */
+  /* eslint-disable prefer-const */
+  let { control, value, onChange } = $props();
+  /* eslint-enable prefer-const */
+
+  /** @type {HTMLElement | undefined} */
+  let container = $state();
+  /** @type {import('react-dom/client').Root | undefined} */
+  let reactRoot = $state();
+
+  onMount(() => {
+    reactRoot = createRoot(/** @type {HTMLElement} */ (container));
+
+    return () => {
+      reactRoot?.unmount();
+    };
+  });
+
+  $effect(() => {
+    reactRoot?.render(createElement(control, { value, onChange }));
+  });
+</script>
+
+<div class="react-editor-component-control" bind:this={container}></div>
+
+<style>
+  .react-editor-component-control {
+    width: 100%;
+  }
